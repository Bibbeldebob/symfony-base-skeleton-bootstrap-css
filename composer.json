{
    "name": "bibbeldebob/php-skeleton",
    "description": "A PHP Skeleton with devcontainer for easy and quick start of new projects",
    "type": "project",
    "config": {
        "platform": {
            "php": "8.5.3"
        },
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "symfony/framework-bundle": "^8.0",
        "twig/twig": "^3.24",
        "symfony/twig-bundle": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/form": "^8.0",
        "symfony/console": "^8.0",
        "symfony/yaml": "^8.0",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/orm": "^3.6",
        "symfony/runtime": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/flex": "^2.10",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/asset": "^8.0",
        "twig/extra-bundle": "^2.12|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "friendsofphp/php-cs-fixer": "^3.94",
        "symfony/debug-bundle": "^8.0"
    },
    "scripts": {
        "unit": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse -c phpstan.dist.neon -vv",
        "rector-dry": "vendor/bin/rector process --dry-run",
        "rector": "vendor/bin/rector",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-fix-dry": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "codecheck": [
            "@php -r \"echo PHP_EOL . '==== UNIT TESTS ====' . PHP_EOL;\"",
            "@unit",
            "@php -r \"echo PHP_EOL . '==== PHPSTAN ====' . PHP_EOL;\"",
            "@stan",
            "@php -r \"echo PHP_EOL . '==== RECTOR ====' . PHP_EOL;\"",
            "@rector",
            "@php -r \"echo PHP_EOL . '==== CS FIXER ====' . PHP_EOL;\"",
            "@cs-fix"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    }
}
